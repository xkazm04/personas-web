# personas-web — environment template
# Copy to .env.local and fill in values. All NEXT_PUBLIC_* vars are inlined
# into the client bundle at build time — never put secrets here.
#
# The app boots without any of these set; Supabase- and orchestrator-backed
# features simply degrade (no voting persistence, no live dashboard, etc.).

# ── Supabase ────────────────────────────────────────────────────────────────
# Required for: /api/feature-requests, /api/votes, /api/feature-comments,
# /api/feature-boosts, /api/roadmap, auth store. Provision the voting tables
# once with scripts/setup-voting-db.sql in the Supabase SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Orchestrator (external agent runtime) ───────────────────────────────────
# Required for: /dashboard/* live data, /api/events/stream SSE proxy.
# Leave unset to run dashboard on mocks (see NEXT_PUBLIC_USE_MOCK_API).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3001
# Server-only orchestrator credential. Attached to orchestrator requests by the
# /api/orchestrator proxy and the SSE routes — NEVER sent to the browser. Do NOT
# use the NEXT_PUBLIC_ prefix (that would inline the secret into the client bundle).
# NEXT_PUBLIC_TEAM_API_KEY is still read as a fallback but is deprecated; migrate to TEAM_API_KEY.
TEAM_API_KEY=YOUR_TEAM_API_KEY

# ── Mock mode ───────────────────────────────────────────────────────────────
# Set to "true" to force the dashboard onto mock data even when the
# orchestrator URL is configured. Useful for local UI work. When enabled, the
# /dashboard route auto-authenticates as a demo user — no Supabase sign-in
# step is required.
NEXT_PUBLIC_USE_MOCK_API=true

# ── Dev-only guide topics ───────────────────────────────────────────────────
# Set to "true" to surface guide topics marked `devOnly: true` (drafts /
# WIP). When set, the sidebar shows them with a golden left border as a
# reminder they're hidden in production. Leave unset (or "false") for
# production builds.
NEXT_PUBLIC_SHOW_DEV_GUIDE_TOPICS=false

# ── Language switcher (dev/QA only) ─────────────────────────────────────────
# Set to "true" to surface the footer locale switcher and enable runtime
# language switching. OFF by default: the non-en UI bundles are incomplete and
# partly corrupt, so this must stay disabled in production (the app renders
# English-only when unset). Enable on preview deploys to QA locales as
# translations are repaired.
NEXT_PUBLIC_SHOW_LANGUAGE_SWITCHER=false

# ── Public site URL ─────────────────────────────────────────────────────────
# Used for canonical URLs, OpenGraph tags, sitemap.ts. Defaults to
# https://personas.ai if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sentry (client-side error reporting) ────────────────────────────────────
# If unset, Sentry init is skipped — app works normally, just no reports.
NEXT_PUBLIC_SENTRY_DSN=

# ── Desktop download CTA ────────────────────────────────────────────────────
# URL the "Download" buttons resolve to. If unset, buttons show a waitlist
# form instead.
NEXT_PUBLIC_DOWNLOAD_URL=

# ── Ko-fi tipping (feature voting page) ─────────────────────────────────────
# Leave empty to hide the Ko-fi widget.
NEXT_PUBLIC_KOFI_USERNAME=

# ── Discord community invite ────────────────────────────────────────────────
# Permanent invite URL shown in the FAQ Discord CTA, Footer icon, /community
# page, and /guide CTA. If unset, falls back to https://discord.gg/personas.
# Generated by scripts/setup-discord.mjs on first server provision.
NEXT_PUBLIC_DISCORD_INVITE_URL=

# ── ElevenLabs (server-only, tour narration generation) ─────────────────────
# Used only by the offline script that generates guided-tour narration audio
# (config in scripts/tour-audio.config.mjs). Not read by the app at runtime.
ELEVENLABS_API_KEY=

# ── Sentry source-map upload (server-only, CI) ──────────────────────────────
# Needed only for `npm run build` in CI to upload source maps to Sentry.
# Local dev does not need these.
SENTRY_ORG=
SENTRY_PROJECT=

# ── Release metadata (server-only, exposed via next.config.ts env.*) ────────
# Populates footer release info. Unset = empty strings rendered.
RELEASE_TITLE=
RELEASE_DATE=

# ── Stats cache purge admin token (server-only, optional) ───────────────────
# Bearer token that gates the admin cache-purge on /api/stats (DELETE/POST).
# Leave unset to disable the purge endpoint entirely (it returns 503 when this
# is absent, so it can never be reached unauthenticated). Set to a long random
# secret (e.g. `openssl rand -hex 32`) only in environments where you need to
# force-refresh the cached homepage stats.
STATS_ADMIN_TOKEN=

# ── Auto-injected, do not set manually ──────────────────────────────────────
# NEXT_PUBLIC_APP_VERSION   — read from package.json by next.config.ts
# NEXT_PUBLIC_RELEASE_TITLE — mirrors RELEASE_TITLE above
# NEXT_PUBLIC_RELEASE_DATE  — mirrors RELEASE_DATE above
