{
  "name": "personas-web",
  "version": "0.1.0",
  "description": "Marketing site, demo dashboard, and API routes for Personas — a platform for building and orchestrating multi-agent AI pipelines.",
  "private": true,
  "license": "MIT",
  "keywords": [
    "personas",
    "ai-agents",
    "agent-orchestration",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "supabase"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:inspect": "cross-env DEV_INSPECT=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:guide-content": "node scripts/check-guide-content.mjs",
    "check:i18n-coverage": "node scripts/check-i18n-coverage.mjs",
    "check:i18n-encoding": "node scripts/check-i18n-encoding.mjs",
    "report:i18n-hardcoded": "node scripts/report-hardcoded-ui-strings.mjs",
    "db:migrate": "node scripts/run-voting-migration.mjs",
    "db:migrate:sync": "node scripts/run-sync-migration.mjs",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "shiki": "^4.0.2",
    "swr": "^2.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "pg": "^8.20.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  }
}
